# agent-comms configuration — copy to .env and fill in.
# Server reads ~/.claude/.env first, then this file (later overrides earlier).

# ── Required ──
# Auth mode: localhost (default), lan, or tailnet
AGENT_COMMS_MODE=localhost

# Required for lan/tailnet modes. Generate with: openssl rand -hex 32
# Leave blank for localhost mode.
AGENT_COMMS_TOKEN=

# ── Optional ──
# Where pushes are filed. Default ~/.agent-comms/inbound
# AGENT_COMMS_INBOUND_DIR=/path/to/inbound

# Listen port (default 8090)
# AGENT_COMMS_PORT=8090

# Telegram notifications: off (default), first50, all
# AGENT_COMMS_NOTIFY=off

# Required for Telegram notifications:
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ── Pairing (agent-comms-pair-v1) ──
# Where pairing state lives (identity, peers, pending, blocklist, responses).
# Default ~/.agent-comms — same parent as the inbound dir.
# AGENT_COMMS_HOME=/path/to/state

# Override the host advertised in UDP discovery offers. Auto-detected from
# the first non-loopback IPv4 by default. Set this if your machine has
# multiple network interfaces and you want the offer to point at a
# specific one (e.g. your Tailscale IP).
# AGENT_COMMS_ADVERTISE_HOST=100.x.x.x
